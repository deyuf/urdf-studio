<?xml version="1.0"?>
<!--
  Deliberately broken Franka-like URDF used by lint-rule tests. Each rule
  fires at least once. Comments tag the rule code that the linter must
  trigger so the test asserts both presence and absence of false positives.
-->
<robot name="fr3_broken">

  <!-- R-001: no root link will be detectable; we'll wire link0 as both an
       orphan and a child to also fail multi-root checks. -->
  <link name="orphan_link">
    <visual><geometry><box size="0.1 0.1 0.1"/></geometry></visual>
  </link>

  <link name="fr3_link0">
    <visual><geometry><box size="0.1 0.1 0.1"/></geometry></visual>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- R-004: duplicate link name -->
  <link name="fr3_link0">
    <visual><geometry><box size="0.05 0.05 0.05"/></geometry></visual>
  </link>

  <link name="fr3_link1">
    <visual><geometry><cylinder radius="0.05" length="0.2"/></geometry></visual>
    <!-- P-001: missing inertial on a movable child -->
  </link>

  <link name="fr3_link2">
    <visual>
      <geometry>
        <!-- A-001: mesh path that won't resolve -->
        <mesh filename="package://nonexistent_pkg/meshes/link2.dae"/>
      </geometry>
    </visual>
    <inertial>
      <!-- P-003: negative mass -->
      <mass value="-1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="fr3_link3">
    <visual><geometry><box size="0.1 0.1 0.1"/></geometry></visual>
    <inertial>
      <mass value="1.0"/>
      <!-- P-002: non-positive-definite inertia (negative ixx) -->
      <inertia ixx="-0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="fr3_link4">
    <visual><geometry><box size="0.1 0.1 0.1"/></geometry></visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="fr3_joint1" type="revolute">
    <parent link="fr3_link0"/>
    <child link="fr3_link1"/>
    <axis xyz="0 0 1"/>
    <!-- P-004: missing <limit> for a revolute joint -->
  </joint>

  <joint name="fr3_joint2" type="revolute">
    <parent link="fr3_link1"/>
    <child link="fr3_link2"/>
    <axis xyz="0 0 1"/>
    <!-- P-006: zero effort/velocity -->
    <limit lower="-1.5" upper="1.5" effort="0" velocity="0"/>
  </joint>

  <joint name="fr3_joint3" type="continuous">
    <parent link="fr3_link2"/>
    <child link="fr3_link3"/>
    <axis xyz="0 0 1"/>
    <!-- P-005: continuous joints should not declare angular limits -->
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
  </joint>

  <!-- R-002: parent and child swapped creates a cycle when joint5 closes it -->
  <joint name="fr3_joint4" type="revolute">
    <parent link="fr3_link3"/>
    <child link="fr3_link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
  </joint>

  <joint name="fr3_joint5" type="revolute">
    <parent link="fr3_link4"/>
    <child link="fr3_link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
  </joint>

  <!-- R-003: parent link does not exist -->
  <joint name="fr3_dangling" type="revolute">
    <parent link="missing_link"/>
    <child link="fr3_link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>

  <!-- R-005: mimic refers to a joint that does not exist -->
  <joint name="fr3_mimic_bad" type="prismatic">
    <parent link="fr3_link4"/>
    <child link="orphan_link"/>
    <axis xyz="0 1 0"/>
    <mimic joint="ghost_joint" multiplier="1" offset="0"/>
    <limit lower="0" upper="0.04" effort="1" velocity="1"/>
  </joint>

</robot>
