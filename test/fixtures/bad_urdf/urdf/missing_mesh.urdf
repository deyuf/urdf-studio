<?xml version="1.0"?>
<robot name="missing_mesh">
  <link name="base">
    <visual>
      <geometry>
        <mesh filename="package://bad_urdf/meshes/does_not_exist.stl"/>
      </geometry>
    </visual>
  </link>
  <link name="tip"/>
  <joint name="hinge" type="revolute">
    <parent link="base"/>
    <child link="tip"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
</robot>
